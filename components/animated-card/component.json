{
  "name": "animated-card",
  "displayName": "AnimatedCard",
  "description": "Pressable card with scale, lift, and rotate animation types on press using Reanimated",
  "category": "interactive",
  "version": "1.0.0",
  "files": [
    { "path": "AnimatedCard.tsx", "target": "AnimatedCard.tsx", "type": "component" }
  ],
  "masicnVersion": "^0.1.0",
  "peerDependencies": {
    "react-native-reanimated": ">=3.0.0"
  },
  "registryDependencies": [],
  "tags": ["interactive", "animation", "card"],
  "hasTests": false,
  "hasAccessibility": false,
  "props": [
    {
      "name": "children",
      "type": "ReactNode",
      "required": true,
      "description": "Content rendered inside the card."
    },
    {
      "name": "onPress",
      "type": "() => void",
      "required": false,
      "description": "Optional press handler; animations only play when this is provided."
    },
    {
      "name": "animation",
      "type": "'scale' | 'lift' | 'rotate' | 'none'",
      "default": "scale",
      "required": false,
      "description": "Animation type played on press."
    },
    {
      "name": "variant",
      "type": "'elevated' | 'filled' | 'outlined'",
      "default": "elevated",
      "required": false,
      "description": "Visual style variant of the card."
    },
    {
      "name": "surface",
      "type": "'primary' | 'secondary' | 'tertiary'",
      "default": "primary",
      "required": false,
      "description": "Background surface color token."
    },
    {
      "name": "shadow",
      "type": "keyof Elevation",
      "default": "lg",
      "required": false,
      "description": "Shadow level applied when using the elevated variant."
    },
    {
      "name": "disabled",
      "type": "boolean",
      "default": "false",
      "required": false,
      "description": "When true, the card is non-interactive and visually dimmed."
    },
    {
      "name": "style",
      "type": "ViewStyle",
      "required": false,
      "description": "Additional style applied to the card."
    }
  ]
}
