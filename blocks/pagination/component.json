{
  "name": "pagination",
  "displayName": "Pagination",
  "description": "Pagination block with page numbers and navigation controls.",
  "category": "blocks",
  "version": "0.0.1",
  "files": [
    {
      "path": "Pagination.tsx",
      "target": "Pagination.tsx",
      "type": "component"
    }
  ],
  "masicnVersion": "^0.0.1",
  "peerDependencies": {},
  "registryDependencies": [
    "button"
  ],
  "tags": [
    "pagination",
    "page",
    "navigation"
  ],
  "hasTests": false,
  "hasAccessibility": true,
  "props": [
    {
      "name": "page",
      "type": "number",
      "required": true,
      "description": "Current active page, 1-based index."
    },
    {
      "name": "totalPages",
      "type": "number",
      "required": true,
      "description": "Total number of pages available."
    },
    {
      "name": "onPageChange",
      "type": "(page: number) => void",
      "required": true,
      "description": "Called with the new page number when a page button or prev/next arrow is pressed."
    },
    {
      "name": "maxVisible",
      "type": "number",
      "default": "5",
      "required": false,
      "description": "Maximum number of page buttons visible before collapsing excess pages to an ellipsis."
    }
  ]
}
